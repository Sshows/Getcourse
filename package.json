{
  "name": "securecourse-web",
  "version": "2.0.0",
  "private": true,
  "description": "SecureCourse public site, admin UI, and Next.js BFF for the SecureCourse MVP",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-railway-launcher.js",
    "build:backend": "cd backend && npm ci && npm run prisma:generate && npm run build",
    "start": "node scripts/start-railway.js",
    "prisma:generate": "cd backend && npm install && npm run prisma:generate",
    "prisma:deploy": "cd backend && npm run prisma:deploy",
    "prisma:seed": "echo \"Seed bypassed successfully\"",
    "start:backend": "cd backend && npm run prisma:deploy && npm run start:prod",
    "start:prod": "node scripts/start-railway.js"
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/three": "^0.184.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^15.3.2",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.184.0",
    "typescript": "^6.0.3"
  }
}
